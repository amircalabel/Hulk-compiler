// Programa completo: Fibonacci sequence
function fib(n) {
    if (n <= 1) 
        return n;
    else 
        return fib(n - 1) + fib(n - 2);
}

print "Fibonacci Sequence";
print "==================";

let limit = 15 in {
    for (var i = 0; i < limit; i = i + 1) {
        print "fib(" @ i @ ") = " @ fib(i);
    };
};
